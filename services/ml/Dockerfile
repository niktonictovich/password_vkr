# Базовый образ: облегченный Python 3.11 на Linux Debian (тонкая версия "slim").
# Размер базового образа ~50 МБ против ~900 МБ у полного python:3.11.
FROM python:3.11-slim

# Отключаем буферизацию вывода Python.
# Без этого print() копится во внутреннем буфере и не появляется в логах Docker.
ENV PYTHONUNBUFFERED=1

# Отключаем создание .pyc-файлов внутри контейнера — они не нужны
# и только засоряют файловую систему контейнера.
ENV PYTHONDONTWRITEBYTECODE=1

# Рабочая директория внутри контейнера.
WORKDIR /app

# Сначала устанавливаем зависимости (отдельным слоем для кэширования).
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Копируем код сервиса.
COPY . .

# Документируем порт, на котором будет работать сервис.
EXPOSE 8000

# Запуск ASGI-сервера uvicorn, который обслуживает FastAPI-приложение.
# main:app  — модуль main.py, переменная app внутри него.
# --host 0.0.0.0 — слушать на всех сетевых интерфейсах внутри контейнера
#   (без этого сервис принимал бы запросы только с localhost внутри
#   контейнера, недоступного для других контейнеров).
# --port 8000 — на каком порту слушать (соответствует EXPOSE).
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
