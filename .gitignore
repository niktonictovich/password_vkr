# =====================================================
# Python — служебные файлы языка
# =====================================================

# Скомпилированные версии исходников (создаются Python автоматически)
__pycache__/
*.pyc
*.pyo
*.pyd

# Виртуальные окружения Python (локальные установки библиотек)
.venv/
venv/
env/
ENV/

# Метаданные пакетов
*.egg-info/
*.egg

# Кэш тестов
.pytest_cache/
.coverage
htmlcov/


# =====================================================
# Данные и обученные модели — слишком большие для Git
# =====================================================

# Все содержимое папки data, кроме маркера .gitkeep
data/*
!data/.gitkeep

# Обученные модели Маркова и любые pickle-файлы
*.pkl
*.pickle
*.model
*.bin

# Логи обучения
logs/
*.log


# =====================================================
# Секреты — НИКОГДА не должны попадать в репозиторий
# =====================================================

.env
.env.local
.env.*.local
*.key
*.pem
secrets/


# =====================================================
# Редакторы и IDE — настройки разработчика, не проекта
# =====================================================

# Visual Studio Code
.vscode/

# PyCharm и другие JetBrains
.idea/

# Прочие редакторы
*.swp
*.swo
*~


# =====================================================
# Системные файлы операционных систем
# =====================================================

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS (на случай, если будешь работать с другого компа)
.DS_Store
.AppleDouble


# =====================================================
# Временное и черновое
# =====================================================

tmp/
temp/
*.tmp
*.bak
